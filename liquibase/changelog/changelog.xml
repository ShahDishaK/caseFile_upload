<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
     xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="
     http://www.liquibase.org/xml/ns/dbchangelog
     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">


<!-- ===================== -->
<!-- COMPANIES -->
<!-- ===================== -->

<changeSet id="1-create-companies" author="disha">
    <createTable tableName="companies">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="name" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="address" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="phoneNumber" type="VARCHAR(15)">
            <constraints nullable="false" unique="true"/>
        </column>

        <column name="email" type="VARCHAR(255)"/>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>
</changeSet>

<!-- ===================== -->
<!-- USERS -->
<!-- ===================== -->

<changeSet id="2-create-users" author="disha">

    <createTable tableName="users">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="name" type="VARCHAR(255)">
            <constraints nullable="false" unique="true"/>
        </column>

        <column name="firstName" type="VARCHAR(255)"/>
        <column name="lastName" type="VARCHAR(255)"/>

        <column name="email" type="VARCHAR(255)">
            <constraints nullable="false" unique="true"/>
        </column>

        <column name="phoneNumber" type="VARCHAR(15)">
            <constraints unique="true"/>
        </column>

        <column name="password" type="VARCHAR(255)"/>

        <column name="address" type="VARCHAR(255)"/>

        <column name="role" type="VARCHAR(50)"/>

        <column name="companyId" type="INT"/>

        <column name="isDeleted" type="BOOLEAN"
                defaultValueBoolean="false"/>

        <column name="isBlocked" type="BOOLEAN"
                defaultValueBoolean="false"/>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>

    <addForeignKeyConstraint
            baseTableName="users"
            baseColumnNames="companyId"
            referencedTableName="companies"
            referencedColumnNames="id"
            constraintName="fk_users_company"/>

</changeSet>

<!-- ===================== -->
<!-- CASES -->
<!-- ===================== -->

<changeSet id="3-create-cases" author="disha">

    <createTable tableName="cases">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="caseNumber" type="INT">
            <constraints nullable="false"/>
        </column>

        <column name="title" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="type" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column name="description" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="caseStage" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column name="caseCity" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column name="status" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column name="caseClosedDate" type="DATETIME"/>

        <column name="isDeleted" type="BOOLEAN"
                defaultValueBoolean="false"/>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>

</changeSet>

<!-- ===================== -->
<!-- LAWYERS -->
<!-- ===================== -->

<changeSet id="4-create-lawyers" author="disha">

    <createTable tableName="lawyers">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="userId" type="INT">
            <constraints nullable="false"/>
        </column>

        <column name="specialization" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="caseId" type="INT"/>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>

    <addForeignKeyConstraint
            baseTableName="lawyers"
            baseColumnNames="userId"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_lawyers_user"/>

    <addForeignKeyConstraint
            baseTableName="lawyers"
            baseColumnNames="caseId"
            referencedTableName="cases"
            referencedColumnNames="id"
            constraintName="fk_lawyers_case"/>

</changeSet>

<!-- ===================== -->
<!-- CLIENTS -->
<!-- ===================== -->

<changeSet id="5-create-clients" author="disha">

    <createTable tableName="clients">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="crNumber" type="INT"/>
        <column name="vatNumber" type="INT"/>
        <column name="vatPercentage" type="INT"/>

        <column name="caseId" type="INT"/>
        <column name="lawyerId" type="INT"/>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>

    <addForeignKeyConstraint
            baseTableName="clients"
            baseColumnNames="lawyerId"
            referencedTableName="lawyers"
            referencedColumnNames="id"
            constraintName="fk_clients_lawyer"/>

    <addForeignKeyConstraint
            baseTableName="clients"
            baseColumnNames="caseId"
            referencedTableName="cases"
            referencedColumnNames="id"
            constraintName="fk_clients_case"/>

</changeSet>

<!-- ===================== -->
<!-- TASKS -->
<!-- ===================== -->

<changeSet id="6-create-tasks" author="disha">

    <createTable tableName="tasks">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="title" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="description" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="caseId" type="INT"/>
        <column name="assignedTo" type="INT"/>

        <column name="status" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>

</changeSet>

<!-- ===================== -->
<!-- COURT SESSIONS -->
<!-- ===================== -->

<changeSet id="7-create-courtSessions" author="disha">

    <createTable tableName="courtSessions">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="sessionDate" type="DATETIME">
            <constraints nullable="false"/>
        </column>

        <column name="courtName" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="caseId" type="INT"/>
        <column name="lawyerId" type="INT"/>
        <column name="clientId" type="INT"/>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>

</changeSet>

<!-- ===================== -->
<!-- DOCUMENTS -->
<!-- ===================== -->

<changeSet id="8-create-documents" author="disha">

    <createTable tableName="documents">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="title" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="documentLink" type="VARCHAR(255)">
            <constraints nullable="false"/>
        </column>

        <column name="fileType" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>

        <column name="userId" type="INT">
            <constraints nullable="false"/>
        </column>

        <column name="caseId" type="INT"/>

        <column name="createdAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP"/>

        <column name="updatedAt" type="DATETIME"
                defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>

    </createTable>

    <addForeignKeyConstraint
            baseTableName="documents"
            baseColumnNames="userId"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_documents_user"/>

</changeSet>

<!-- ===================== -->
<!-- EXAMPLE -->
<!-- ===================== -->

<changeSet id="9-create-example" author="disha">

    <createTable tableName="example">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

    </createTable>

</changeSet>


</databaseChangeLog>
